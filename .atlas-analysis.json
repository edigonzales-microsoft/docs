  "keyFeatures": [
    "Cross-platform game development for Xbox Series X|S, Xbox One, and Windows PC",
    "Xbox Services API (XSAPI) for achievements, leaderboards, multiplayer, and social features",
    "MicrosoftGame.config manifest for game identity and packaging configuration",
    "Intelligent Delivery and Streaming Install for optimized package distribution",
    "Xbox Game Streaming and Remote Play support with Cloud Aware APIs",
    "PlayFab integration for backend services, monetization, and multiplayer networking",
    "Multiplayer Session Directory (MPSD), SmartMatch matchmaking, and Game Chat 2",
    "Connected Storage and Title Storage for cloud game saves and assets",
    "Partner Center integration for Microsoft Store publishing and certification",
    "Commerce APIs (XStore) for in-app purchases, DLC, bundles, and consumables",
    "PIX performance profiling for DirectX 12 on PC and Xbox",
    "Xbox Service development tools (sandbox management, data reset, trace analysis)"
  ],
  "publicApiSurface": [
    "XGameRuntimeInitialize() / XGameRuntimeUninitialize()",
    "XGameSave APIs (XGameSaveCreateContainer, XGameSaveSubmitUpdate, etc.)",
    "XStore APIs (XStoreQueryAssociatedProductsAsync, XStorePurchaseProductAsync, etc.)",
    "XPackage APIs (XPackageMount, XPackageEnumerateChunkAvailability, etc.)",
    "XGameStreaming APIs (XGameStreamingIsStreaming, XGameStreamingGetTouchBundleVersion, etc.)",
    "XGameUI APIs (XGameUISShowMessageDialogAsync, etc.)",
    "XAppCapture APIs (XAppCaptureRecordDiagnosticCapture, etc.)",
    "XMem APIs (XMemAlloc / XMemFree)",
    "XSAPI C APIs: XblSocialManagerAddLocalUser, XblSocialManagerDoWork, XblSocialManagerCreateSocialUserGroupFromFilters",
    "XblPresenceFilter / XblRelationshipFilter enumerations",
    "MicrosoftGame.config XML schema elements (Identity, ShellVisuals, ExecutableList, StoreId, etc.)",
    "makepkg.exe / makepkg2.exe for packaging",
    "wdapp.exe (PC) and xbapp.exe (console) for app registration and management",
    "XblConfig.exe, XblConnectedStorage.exe, XblPlayerDataReset.exe, XblTraceAnalyzer.exe (Xbox service tools)"
  ]
}
